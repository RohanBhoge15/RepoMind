# ==========================================
# BACKEND ENVIRONMENT VARIABLES
# ==========================================

# -------- Database --------
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://repomind:password@localhost:5432/repomind

# Alternatively, use individual variables:
POSTGRES_USER=repomind
POSTGRES_PASSWORD=password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=repomind

# -------- Redis --------
# Redis connection URL for caching and job queue
REDIS_URL=redis://localhost:6379

# -------- Qdrant Vector Database --------
# Qdrant connection settings
QDRANT_URL=http://localhost:6333
QDRANT_HOST=localhost
QDRANT_PORT=6333
# For Qdrant Cloud, use:
# QDRANT_URL=https://your-cluster.qdrant.io
# QDRANT_API_KEY=your-api-key

# -------- GitHub OAuth --------
# Get these from https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# -------- AI Provider (NVIDIA NIM) --------
# Get an API key from https://build.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=stepfun-ai/step-3.5-flash

# -------- Security --------
# Secret key for session signing (min 32 characters)
# Generate with: openssl rand -hex 32
SECRET_KEY=your_32_character_minimum_secret_key_here

# -------- Application Settings --------
# Environment: development | production | testing
ENVIRONMENT=development

# Log level: debug | info | warning | error
LOG_LEVEL=info

# CORS settings (comma-separated URLs)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# -------- Optional Settings --------
# Maximum file size for processing (in bytes)
MAX_FILE_SIZE=10485760

# File processing timeout (in seconds)
FILE_PROCESSING_TIMEOUT=300

# Number of parallel AI requests
MAX_PARALLEL_AI_REQUESTS=3

# Enable/disable specific features
ENABLE_BANDIT_SCANNING=true
ENABLE_MERMAID_DIAGRAMS=true
ENABLE_CHAT=true
