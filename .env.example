# ==========================================
# DOCKER COMPOSE ENVIRONMENT VARIABLES
# Copy this file to .env and fill in the values
# ==========================================

# -------- PostgreSQL --------
POSTGRES_USER=repomind
POSTGRES_PASSWORD=repomind_secure_password_change_me
POSTGRES_DB=repomind

# -------- GitHub OAuth --------
# Get these from https://github.com/settings/developers
# Homepage URL: http://localhost:3000
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# -------- AI Provider (NVIDIA NIM) --------
# Get an API key from https://build.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=meta/llama-4-maverick-17b-128e-instruct

# -------- Security --------
# Generate with: openssl rand -hex 32
SECRET_KEY=your_32_character_minimum_secret_key_here
NEXTAUTH_SECRET=your_nextauth_secret_min_32_chars_here

# -------- Application Settings --------
# Environment: development | production | testing
ENVIRONMENT=development
LOG_LEVEL=info
NODE_ENV=development

# -------- URLs (for docker-compose) --------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000

# -------- Qdrant (if using cloud) --------
# QDRANT_URL=https://your-cluster.qdrant.io
# QDRANT_API_KEY=your_qdrant_api_key
